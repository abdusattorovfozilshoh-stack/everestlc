{
  "version": 2,
  "name": "everest-management",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
